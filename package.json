  "dependencies": {
    "eslint-plugin-react-hooks": "^1.6.1",
    "hookrouter": "^1.2.3",
    "lodash": "^4.17.15",
    "node-sass": "^4.13.1",
    "prettier": "^1.18.2",
    "react": "^16.8.6",
    "react-dom": "^16.8.6",
    "react-scripts": "3.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
